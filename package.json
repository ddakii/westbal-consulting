    "framer-motion": "^12.42.2",
    "lucide-react": "^1.25.0",
    "mammoth": "^1.12.0",
    "nanoid": "^6.0.0",
    "next": "16.2.10",
    "openai": "^6.48.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.16.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsx": "^4.23.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
